{
  // Project-specific only. Generic editor/format/exclude defaults come from User settings.

  // Tailwind v4 + Nuxt UI
  "css.lint.unknownAtRules": "ignore",
  "tailwindCSS.classAttributes": ["active-class", "inactive-class", "ui"],
  "tailwindCSS.experimental.classRegex": [
    ["ui:\\s*{([^)]*)\\}", "[\"'`]([^\"'`]*).*?[\"'`]"],
    ["/\\*ui\\*/\\s*{([^;]*)}", ":\\s*[\"'`]([^\"'`]*).*?[\"'`]"]
  ],
  "files.associations": {
    "*.css": "tailwindcss"
  },

  // Workspace TS + Nuxt conventions (js/ts.* unified namespace)
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "js/ts.preferences.quoteStyle": "single",
  "typescript.inlayHints.parameterNames.enabled": "literals",
  "typescript.inlayHints.functionLikeReturnTypes.enabled": true,

  // Merged with User (which has source.fixAll.eslint: explicit)
  "editor.codeActionsOnSave": {
    "source.organizeImports": "never"
  },

  // Tailwind autocomplete inside strings
  "editor.quickSuggestions": {
    "strings": true
  },

  // Project-specific extras to User excludes
  "files.exclude": {
    "**/generated": true
  },

  // File nesting (group related files)
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.spec.ts, ${capture}.test.ts, ${capture}.d.ts",
    "*.vue": "${capture}.spec.ts, ${capture}.test.ts",
    "package.json": "pnpm-lock.yaml, pnpm-workspace.yaml, .npmrc"
  },

  // i18n
  "i18n-ally.keystyle": "nested"
}
